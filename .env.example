# Server
PORT=3000
NODE_ENV=development

# The Odds API — https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key
ODDS_DEFAULT_REGION=us
ODDS_DEFAULT_MARKETS=h2h,spreads,totals
ODDS_DEFAULT_FORMAT=american

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_DEFAULT_TEMPERATURE=0.7

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# Admin key for ?fresh=true and per-event live AI endpoints
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# Picks cron (UTC by default; daily at 10:00 UTC = 6 AM ET)
PICKS_CRON=0 10 * * *
PICKS_CRON_TZ=UTC

# SMTP (for digests / notifications — not yet wired)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
